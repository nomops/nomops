{
  "name": "@nomops/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nomops/core": "workspace:*",
    "@nomops/db": "workspace:*",
    "@nomops/nodes": "workspace:*",
    "@nomops/workflow": "workspace:*",
    "argon2": "^0.41.1",
    "bullmq": "^5.79.3",
    "express": "^5.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^7.3.1",
    "openid-client": "^6.8.4",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express-serve-static-core": "^5.1.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ws": "^8.5.13"
  }
}
